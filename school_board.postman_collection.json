{
  "info": {
    "name": "School Board API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/auth/register/",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"username\": \"testuser\",\n  \"password\": \"123456\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/auth/verify-email/",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"code\": \"123456\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/auth/login/",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"123456\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/auth/logout/",
            "header": []
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:8000/auth/me/",
            "header": []
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:8000/api/categories/",
            "header": []
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/api/categories/",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Science\",\n  \"parent\": null\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "http://127.0.0.1:8000/api/categories/1/delete/",
            "header": []
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
